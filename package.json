{
  "name": "iterm2-node",
  "version": "0.1.1",
  "description": "TypeScript client for the iTerm2 WebSocket API. Faithful port of the official Python `iterm2` package.",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "proto",
    "LICENSE",
    "README.md"
  ],
  "license": "MIT",
  "author": "Dj Padzensky <djpadz@padz.net>",
  "homepage": "https://github.com/djpadz/iterm2-node#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/djpadz/iterm2-node.git"
  },
  "bugs": {
    "url": "https://github.com/djpadz/iterm2-node/issues"
  },
  "keywords": [
    "iterm2",
    "iterm",
    "terminal",
    "macos",
    "websocket",
    "protobuf",
    "automation"
  ],
  "scripts": {
    "codegen": "pbjs -t static-module -w commonjs --force-number --null-defaults -o src/generated/api.js proto/api.proto && pbts -o src/generated/api.d.ts src/generated/api.js",
    "build": "tsc -p tsconfig.json && node scripts/copy-generated.js",
    "clean": "rm -rf dist",
    "typecheck": "tsc -p tsconfig.examples.json",
    "test": "tsx --test test/*.test.ts",
    "test:live": "ITERM2_TEST_MODE=live tsx --test test/shared.test.ts test/live.test.ts",
    "test:live:mutate": "ITERM2_TEST_MUTATE=1 npm run test:live",
    "prepare": "[ -f src/generated/api.js ] || npm run codegen && npm run build",
    "prepublishOnly": "npm run clean && npm run codegen && npm run build && npm test",
    "example:list-sessions": "tsx examples/list-sessions.ts",
    "example:notifications": "tsx examples/notifications.ts",
    "example:app-tree": "tsx examples/app-tree.ts"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@types/ws": "^8.5.10",
    "protobufjs": "^8.6.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "protobufjs-cli": "^2.5.2",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "os": [
    "darwin",
    "linux"
  ]
}
